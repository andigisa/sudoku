{
  "name": "sudoku-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @sudoku/domain build && pnpm --filter @sudoku/contracts build && pnpm --filter @sudoku/web build && pnpm --filter @sudoku/server build",
    "dev": "concurrently \"pnpm --filter @sudoku/server dev\" \"pnpm --filter @sudoku/web dev\"",
    "test": "pnpm --filter @sudoku/domain test",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.1"
  }
}
